///|
test "select golden: 6v6 single, team faster than opponent" {
  let team_speeds = [120, 115, 110, 105, 100, 95]
  let opp_speeds = [80, 75, 70, 65, 60, 55]
  let out = run_select(build_select_input(team_speeds, opp_speeds))
